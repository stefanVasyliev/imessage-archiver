{
  "name": "imessage-archiver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local macOS iMessage attachment archiver prototype",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "inspect:chat": "tsx src/scripts/inspectChat.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "image-hash": "^7.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
